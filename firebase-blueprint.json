{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "mode": { "type": "string", "enum": ["Dev AI", "Dev AI Code"] },
        "personality": { "type": "string" },
        "theme": { "type": "string" },
        "colorTheme": { "type": "string" },
        "vibration": { "type": "boolean" },
        "memory": { "type": "string" },
        "fullscreenEditor": { "type": "boolean" },
        "notificationsEnabled": { "type": "boolean" },
        "customization": {
          "type": "object",
          "properties": {
            "fontSize": { "type": "string" },
            "fontFamily": { "type": "string" },
            "primaryColor": { "type": "string" },
            "textColor": { "type": "string" },
            "backgroundColor": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "mode", "personality", "createdAt", "updatedAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "mode": { "type": "string", "enum": ["Dev AI", "Dev AI Code"] },
        "isPublic": { "type": "boolean" },
        "collaborators": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "mode", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dataUrl": { "type": "string" },
              "mimeType": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and settings"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "User's chat sessions"
    },
    "/users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages within a chat session"
    }
  }
}
